# VOC provider configuration placeholders.
# Copy to .env or export these in the runtime environment. Never commit real values.

OPENAI_API_KEY=replace-with-openai-api-key
DEEPSEEK_API_KEY=replace-with-deepseek-api-key
MIMO_API_KEY=replace-with-xiaomi-mimo-api-key
OLLAMA_API_KEY=replace-with-ollama-cloud-api-key

# Optional local Ollama endpoint override.
OLLAMA_BASE_URL=http://127.0.0.1:11434
